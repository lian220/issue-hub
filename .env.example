# ===========================================
# Database (Aiven PostgreSQL - 원격)
# ===========================================
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=issuehub
POSTGRES_USER=
POSTGRES_PASSWORD=
# Aiven SSL 연결 (필수)
POSTGRES_SSL_MODE=require

# ===========================================
# Cache (Upstash Redis - 원격)
# ===========================================
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
# Upstash TLS 연결
REDIS_SSL=true

# ===========================================
# Kafka (Phase 2+, docker-compose --profile phase2)
# ===========================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===========================================
# External Integrations
# ===========================================
JIRA_BASE_URL=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=

SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

TEAMS_APP_ID=
TEAMS_APP_SECRET=

# ===========================================
# AI/Embedding
# ===========================================
OPENAI_API_KEY=

# ===========================================
# Security
# ===========================================
JWT_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-32-char-key-here!!!!!
