# ===========================================
# IssueHub 환경변수 템플릿
# 복사해서 .env 또는 .env.local로 사용
# ===========================================

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=issuehub
POSTGRES_USER=issuehub
POSTGRES_PASSWORD=issuehub_dev
POSTGRES_SSL_MODE=disable

# --- Cache ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- n8n ---
N8N_USER=admin
N8N_PASSWORD=issuehub_dev
NEXT_PUBLIC_N8N_URL=http://localhost:5678

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=issuehub_dev
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/issuehub

# --- External Integrations ---
JIRA_BASE_URL=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
TEAMS_APP_ID=
TEAMS_APP_SECRET=

# --- AI/Embedding ---
OPENAI_API_KEY=

# --- Security ---
JWT_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-32-char-key-here!!!!!
